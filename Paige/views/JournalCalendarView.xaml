<UserControl x:Class="Paige.views.JournalCalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <!-- Create a ListBox for the journal entries using a binding -->
        <ListBox ItemsSource="{Binding JournalEntries}" HorizontalContentAlignment="Stretch" >

            <!-- Customize the container template to remove border and highlight, just show the button -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <!-- Customize the item template to customize how each entry is displayed -->
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="30">

                        <!-- Make each item a button to allow you to go to view the entry. Use a stackpanel to summarize the info (which in this case is just date it was written) -->
                        <Button Command="{Binding DataContext.JournalEntryButtonCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                            <Button.Content>
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock FontWeight="Bold" Text="{Binding FirstEdited, StringFormat='Journal entry from {0:MMMM dd, yyyy}'}" />
                                    <TextBlock Text="{Binding LastEdited, StringFormat='Last edited at {0:h:mm tt}'}" />
                                </StackPanel>
                            </Button.Content>
                        </Button>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <!-- Create a back button -->
        <Button Command="{Binding BackCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Content="Back" />

    </Grid>
</UserControl>
