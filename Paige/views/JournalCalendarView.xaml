<UserControl x:Class="Paige.views.JournalCalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <!-- Create a padding column on the left and two actual columns on the right, with one of size auto (for the button -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Same thing as above, but with rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Create a back button -->
        <Button Grid.Row="0" Grid.Column="2" Command="{Binding BackCommand}">
            <Button.Content>
                <TextBlock Style="{StaticResource NormalText}" Text="Back" />
            </Button.Content>
        </Button>
        
        <!-- Create a hidden textblock at the top left that mimics the exact same size of the back button -->
        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource NormalText}" Text="Back" Opacity="0" />

        <!-- Create a ListBox for the entries using a binding -->
        <ListBox Grid.Row="1" Grid.Column="1" BorderBrush="Transparent" ItemsSource="{Binding JournalEntries}" HorizontalContentAlignment="Stretch" >

            <!-- Customize the container template to remove border and highlight, just show the button -->
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <!-- Customize the item template to customize how each entry is displayed -->
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>

                        <!-- Add two rows, one for content and one for padding -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Make each item a button to allow you to go to view the detailed look at the log. Use a stackpanel to summarize the info -->
                        <Button Grid.Row="0" Command="{Binding DataContext.JournalEntryButtonCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                            <Button.Content>
                                <StackPanel HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource NormalText}" FontWeight="Bold" Text="{Binding FirstEdited, StringFormat='Journal entry from {0:MMMM, dd, yyyy}'}" />
                                    <TextBlock Style="{StaticResource NormalText}" Text="{Binding FirstEdited, StringFormat='First edited at {0:h:mm tt}'}" />
                                    <TextBlock Style="{StaticResource NormalText}" Text="{Binding LastEdited, StringFormat='Last edited at {0:h:mm tt}'}" />
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <!-- Make an invisible textblock for the padding using text that scales with window size -->
                        <TextBlock Grid.Row="1" Opacity="0" Style="{StaticResource HeaderText1}" Text="hi :33" />

                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>
</UserControl>
