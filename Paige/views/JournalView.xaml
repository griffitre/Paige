<UserControl x:Class="Paige.views.JournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <!-- Split the grid into 3 rows, one for a text block and textbox, 2 at the top and bottom for padding -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Add a grid to the middle row -->
        <Grid Grid.Row="1">

            <!-- Add padding columns to the sides -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Split into two rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="10*" />
            </Grid.RowDefinitions>

            <!-- Add a textblock prompting the user to begin typing, also show the current date -->
            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource HeaderText1}" Text="{Binding CurrentDate, StringFormat='Journal entry for {0}'}" />
            
            <!-- Add a text box for the user to type in -->
            <TextBox Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" AcceptsReturn="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{StaticResource NormalTextBox}" Text="{Binding JournalBody, UpdateSourceTrigger=PropertyChanged}" />

        </Grid>
        
        <!-- Wrap panel for done and back buttons -->
        <WrapPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Right">
            <Button Command="{Binding ExitCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Exit" />
                </Button.Content>
            </Button>
            <Button Command="{Binding DoneCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Done" />
                </Button.Content>
            </Button>
        </WrapPanel>

    </Grid>
</UserControl>
