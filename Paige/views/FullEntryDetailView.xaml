                    <Grid>

                        <!-- Split into 4 cells, with the top row being sized automatically, and the other row being sized statically -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="600" />
                        </Grid.RowDefinitions>

                        <!-- Display the note header -->
                        <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Text="Here was the note you left:" />

                        <!-- Another grid to layout the "view todays journal" button and the note textbox -->
                        <Grid Grid.Row="1" Grid.Column="0" Margin="10">
                            
                            <!-- Split the grid into two rows -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Display the user's note in a read only textblock -->
                            <TextBox Grid.Row="0" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" Text="{Binding SavedNote, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                            <!-- Add a button that allows the user to check that day's journal -->
                            <Button Grid.Row="1" MaxHeight="10000" MaxWidth="10000" Height="Auto" Width="Auto" Command="{Binding ViewJournalCommand}" CommandParameter="{Binding TodaysEntry}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,10,0,0" Content="View today's Journal..." />

                        </Grid>

                        <!-- Display the image header -->
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Text="Here is the image you attached:" />

                        <!-- Display the attached image as a button so that the user can click it to see the full image. Have a textblock behind to show that no image was attached if applicable -->
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding AttachedImagePath, Converter={StaticResource NullToVisibilityConverter}}" Margin="10" Text="No Image Attached!" />
                        <Button Grid.Row="1"  Grid.Column="1" MaxHeight="10000" MaxWidth="10000" Height="Auto" Width="Auto" Command="{Binding ViewImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NotNullToVisibilityConverter}}" Margin="10" Background="White">
                            <Image MaxHeight="10000" MaxWidth="10000" Source="{Binding AttachedImagePath}" Stretch="Uniform" />
                        </Button>


                    </Grid>

                </StackPanel>

            </Grid>

        </ScrollViewer>

    </Grid>

</UserControl>
