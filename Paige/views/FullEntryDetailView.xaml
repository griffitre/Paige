                    <Button Grid.Row="33" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=2}">
                        <Image Source="/assets/weather/Weather2Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=3}">
                        <Image Source="/assets/weather/Weather3Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=4}">
                        <Image Source="/assets/weather/Weather4Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=5}">
                        <Image Source="/assets/weather/Weather5Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=6}">
                        <Image Source="/assets/weather/Weather6Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=7}">
                        <Image Source="/assets/weather/Weather7Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=8}">
                        <Image Source="/assets/weather/Weather8Placeholder.png" />
                    </Button>

                    <!-- Display the note the user left and the image they attached -->
                    <!-- Headers -->
                    <TextBlock Grid.Row="36" Grid.Column="0" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource FullLogHeaderText}" Text="Here is the note you left:" />
                    <TextBlock Grid.Row="36" Grid.Column="10" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource FullLogHeaderText}" Text="Here is the image you attached:" />
                    
                    <!-- TextBox for the note -->
                    <TextBox Grid.Row="37" Grid.Column="0" Grid.ColumnSpan="10" VerticalAlignment="Stretch" BorderBrush="LightGray" BorderThickness="2" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" Style="{StaticResource NormalTextBox}" Text="{Binding SavedNote, UpdateSourceTrigger=PropertyChanged}" Margin="10" />

                    <!-- Image button and the "No Image Attached!" overlay border -->
                    <Border Grid.Row="37" Grid.Column="10" Grid.ColumnSpan="10" BorderBrush="LightGray" BorderThickness="2" Margin="10">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource FullLogHeaderText}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NullToVisibilityConverter}}" Text="No Image Attached!" />
                    </Border>
                    <Button Grid.Row="37" Grid.Column="10" Grid.ColumnSpan="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ViewImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NotNullToVisibilityConverter}}" Margin="10" Background="White">
                        <Image Source="{Binding AttachedImagePath}" Stretch="Uniform" />
                    </Button>
                    
                    <!-- View journal entry button, spanning the full width -->
                    <Button Grid.Row="38" Grid.Column="0" Grid.ColumnSpan="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ViewJournalCommand}" CommandParameter="{Binding TodaysEntry}" Margin="10">
                        <Button.Content>
                            <TextBlock Style="{StaticResource HeaderText2}" Text="View today's journal..." />
                        </Button.Content>
                    </Button>

                </Grid>

            </Grid>

        </ScrollViewer>

    </Grid>

</UserControl>
