    <!-- Use a style to make scrollviewer's scrollbar smaller -->
    <Control.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10" />
                    <Setter Property="MinWidth" Value="10" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Control.Resources>

    <Grid Background="White">

        <!-- Split main grid into two parts: one for the back button at the top, one for the content -->
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="60*" />
        </Grid.RowDefinitions>

        <!-- Create Delete, Back, and Exit buttons to allow user to exit. Put them in a wrappanel to align them at the top right -->
        <WrapPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Command="{Binding DeleteCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Delete" />
                </Button.Content>
            </Button>
            <Button Command="{Binding BackCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Back" />
                </Button.Content>
            </Button>
            <Button Command="{Binding ExitCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Exit" />
                </Button.Content>
            </Button>
        </WrapPanel>
        

        <!-- Create a scroll viewer in the second row to allow the user to scroll through the entry -->
        <ScrollViewer Grid.Row="1">

            <!-- Create a grid in the scroll viewer -->
            <Grid>

                <!-- Add padding columns -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Grid to layout/display the entry details -->
                <Grid Grid.Column="1">

                    <!-- Define resources/styles -->
                    <Grid.Resources>

                        <!-- Define a custom style of text to go underneath buttons, kind of like a caption -->
                        <Style x:Key="TextButton" TargetType="TextBlock" BasedOn="{StaticResource Subtext}">
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>

                        <!-- Define a custom style for header text -->
                        <Style x:Key="FullLogHeaderText" TargetType="TextBlock" BasedOn="{StaticResource HeaderText2}">
                            <Setter Property="Margin" Value="0,0,0,5" />
                        </Style>

