                    <!-- Textbox for user input, Textblock overlayed over top of the Textbox to act like a hint -->
                    <Grid Grid.Row="3" Grid.Column="1">
                        <TextBox Name="NoteBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" BorderBrush="LightGray" BorderThickness="2" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource NormalTextBox}" Text="{Binding JournalNote, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="2,2,0,0" Visibility="{Binding ElementName=NoteBox, Path=Text, Converter={StaticResource NullToVisibilityConverter}}" IsHitTestVisible="False" Foreground="Gray" Style="{StaticResource NormalText}" Text="Start Here..." />
                    </Grid>

                    <!-- Add a button to allow the user to attach an image. Shown when no image has been attached yet -->
                    <Button Grid.Row="3" Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NullToVisibilityConverter}}" />

                    <!-- If an image is selected, display it -->
                    <Button Grid.Row="3" Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NotNullToVisibilityConverter}}" Background="Transparent">
                        <Image Source="{Binding AttachedImagePath}" Stretch="Uniform" />
                    </Button>

                </Grid>

            </Grid>

        </Grid>

    </Grid>
</UserControl>
