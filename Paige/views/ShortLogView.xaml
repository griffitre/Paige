<UserControl x:Class="Paige.views.ShortLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="430" d:DesignWidth="800">
    <Grid Background="White">

        <!-- Split the grid into two rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10*" />
        </Grid.RowDefinitions>

        <!-- Create Back and Done buttons to allow user to exit/save. Put them in a wrappanel to align them at the top right -->
        <WrapPanel HorizontalAlignment="Right">
            <Button Command="{Binding BackCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Back" />
                </Button.Content>
            </Button>
            <Button Command="{Binding DoneCommand}">
                <Button.Content>
                    <TextBlock Style="{StaticResource NormalText}" Text="Done" />
                </Button.Content>
            </Button>
        </WrapPanel>
        
        <!-- Grid for the headers -->
        <Grid Grid.Row="1">
            
            <!-- Split the grid into 2 columns -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
                
            </Grid.ColumnDefinitions>

            <!-- Prompt user to choose how they're currently feeling -->
            <TextBlock Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource HeaderText1}" Text="How are you feeling?" />

            <!-- Prompt user to enter how good their day was -->
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource HeaderText1}" Text="How was your day, out of 10?" />

        </Grid>

        <Grid Grid.Row="2">

            <!-- Split the grid into 2 columns -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- Set up a grid in the left column -->
            <Grid Grid.Column="0">

                <!-- Split the left column into 5 rows -->
                <!-- Also add a padding row to the bottom -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Split into 2 columns -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Add mood images to left column in the grid in the left column (idk how else you'd say that my bad if it's confusing) -->
                <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding Mood5Command}" Background="{Binding CurrentMood, Converter={StaticResource SelectedValueToColourConverter}, ConverterParameter=5}">
                    <Image Stretch="Uniform" Source="/assets/mood/Mood5Placeholder.png" />
                </Button>
