                                <Image Source="/assets/mood/Mood3Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Okay" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <Button Command="{Binding Mood4Command}" Background="{Binding CurrentMood, Converter={StaticResource SelectedValueToColourConverter}, ConverterParameter=4}">
                                <Image Source="/assets/mood/Mood4Placeholder.png" />
