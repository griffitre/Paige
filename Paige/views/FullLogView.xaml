                            <TextBlock Style="{StaticResource TextButton}" Text="Hail" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <Button Command="{Binding ToggleWeather4Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=4}">
                                <Image Source="/assets/weather/Weather4Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Stormy" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <Button Command="{Binding ToggleWeather5Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=5}">
                                <Image Source="/assets/weather/Weather5Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Snowy" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <Button Command="{Binding ToggleWeather6Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=6}">
                                <Image Source="/assets/weather/Weather6Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Windy" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <Button Command="{Binding ToggleWeather7Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=7}">
                                <Image Source="/assets/weather/Weather7Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Cold" />
                        </StackPanel>

                        <StackPanel Margin="0,0,10,0">
                            <Button Command="{Binding ToggleWeather8Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=8}">
                                <Image Source="/assets/weather/Weather8Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Hot/" />
                            <TextBlock Style="{StaticResource TextButton}" Text="Humid" />
                        </StackPanel>

                    </WrapPanel>

                    <!-- Grid for note and attaching an image -->
                    <Grid>

                        <!-- Split into 4 cells, with the top row being sized automatically -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Prompt the user to enter a note for the day, optionally -->
                        <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Text="Any notes? (Optional)" />

                        <!-- Textbox for the user to enter their note -->
                        <TextBox Grid.Row="1" Grid.Column="0" Height="600" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding JournalNote, UpdateSourceTrigger=PropertyChanged}" Margin="10" />

                        <!-- Prompt the user to add an image, also optionally -->
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Text="Attach an image below! (Also Optional)" />

                        <!-- For the following two buttons, override the button dimensions defined in the stackpanel resources -->
                        <!-- Button for user to attach an image -->
                        <Button Grid.Row="1" Grid.Column="1" Height="Auto" Width="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NullToVisibilityConverter}}" Margin="10" />

                        <!-- If an image is selected, display it in a button that they can click to change the image if theyd like -->
                        <Button Grid.Row="1" Grid.Column="1" Height="Auto" Width="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NotNullToVisibilityConverter}}" Background="Transparent" Margin="10">
                            <Image Source="{Binding AttachedImagePath}" Stretch="Uniform" />
                        </Button>

                    </Grid>

                </StackPanel>

            </Grid>
            
        </ScrollViewer>
        
    </Grid>
    
</UserControl>
