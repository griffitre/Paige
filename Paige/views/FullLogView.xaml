                    </Button>
                    <Button Grid.Row="29" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleRecreational2Command}" Background="{Binding Recreational, Converter={StaticResource ListContainsConverter}, ConverterParameter=2}">
                        <Image Source="/assets/recreationaluse/RecreationalUse2Placeholder.png" />
                    </Button>
                    <Button Grid.Row="29" Grid.Column="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleRecreational3Command}" Background="{Binding Recreational, Converter={StaticResource ListContainsConverter}, ConverterParameter=3}">
                        <Image Source="/assets/recreationaluse/RecreationalUse3Placeholder.png" />
                    </Button>
                    <Button Grid.Row="29" Grid.Column="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleRecreational4Command}" Background="{Binding Recreational, Converter={StaticResource ListContainsConverter}, ConverterParameter=4}">
                        <Image Source="/assets/recreationaluse/RecreationalUse4Placeholder.png" />
                    </Button>

                    <!-- Weather Buttons -->
                    <Button Grid.Row="33" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather1Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=1}">
                        <Image Source="/assets/weather/Weather1Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather2Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=2}">
                        <Image Source="/assets/weather/Weather2Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather3Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=3}">
                        <Image Source="/assets/weather/Weather3Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather4Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=4}">
                        <Image Source="/assets/weather/Weather4Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather5Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=5}">
                        <Image Source="/assets/weather/Weather5Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather6Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=6}">
                        <Image Source="/assets/weather/Weather6Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather7Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=7}">
                        <Image Source="/assets/weather/Weather7Placeholder.png" />
                    </Button>
                    <Button Grid.Row="33" Grid.Column="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Command="{Binding ToggleWeather8Command}" Background="{Binding Weather, Converter={StaticResource ListContainsConverter}, ConverterParameter=8}">
                        <Image Source="/assets/weather/Weather8Placeholder.png" />
                    </Button>

                    <!-- Prompt the user to enter a note -->
                    <!-- Headers -->
                    <TextBlock Grid.Row="36" Grid.Column="0" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource FullLogHeaderText}" Text="Any notes?" />
                    <TextBlock Grid.Row="37" Grid.Column="0" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource NormalText}" Text="(Optional)" />
                    <TextBlock Grid.Row="36" Grid.Column="10" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource FullLogHeaderText}" Text="Attach an image below!" />
                    <TextBlock Grid.Row="37" Grid.Column="10" Grid.ColumnSpan="10" HorizontalAlignment="Center" Style="{StaticResource NormalText}" Text="(Also optional)" />

                    <!-- TextBox for the note -->
                    <TextBox Grid.Row="38" Grid.Column="0" Grid.ColumnSpan="10" BorderBrush="LightGray" BorderThickness="2" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource NormalTextBox}" Text="{Binding SavedNote, UpdateSourceTrigger=PropertyChanged}" Margin="10" />

                    <!-- Add a button to allow the user to attach an image. Shown when no image has been attached yet -->
                    <Button Grid.Row="38" Grid.Column="10" Grid.ColumnSpan="10" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NullToVisibilityConverter}}" Margin="10" />

                    <!-- If an image is selected, display it -->
                    <Button Grid.Row="38" Grid.Column="10" Grid.ColumnSpan="10" Command="{Binding AttachImageCommand}" Visibility="{Binding AttachedImagePath, Converter={StaticResource NotNullToVisibilityConverter}}" Background="Transparent" Margin="10">
                        <Image Source="{Binding AttachedImagePath}" Stretch="Uniform" />
                    </Button>

                </Grid>

            </Grid>

        </ScrollViewer>

    </Grid>

</UserControl>
