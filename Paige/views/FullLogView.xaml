<UserControl x:Class="Paige.views.FullLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="2000" d:DesignWidth="800">
    
    <!-- Use a style to make scrollviewer's scrollbar smaller -->
    <Control.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10" />
                    <Setter Property="MinWidth" Value="10" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Control.Resources>

    <Grid Background="White">
        
        <!-- Split main grid into two parts: one for the back/main buttons at the top, one for the content -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="60*" />
        </Grid.RowDefinitions>
        
        <!-- Create back and main buttons to allow user to exit. Put them in a wrappanel to align them at the top right -->
        <WrapPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Command="{Binding BackCommand}" Content="Back" />
            <Button Command="{Binding DoneCommand}" Content="Done" />
        </WrapPanel>
        
        <!-- Create a scroll viewer in the second row to allow the user to scroll up and down to give inputs for all fields -->
        <ScrollViewer Grid.Row="1">
            
            <!-- Create a grid in the scroll viewer -->
            <Grid>
                
                <!-- Add padding columns -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Stackpanel to give the options -->
                <StackPanel Grid.Column="1">

                    <!-- Define resources/styles -->
                    <StackPanel.Resources>

                        <!-- Define a custom style of text to go underneath buttons, kind of like a caption -->
                        <Style x:Key="TextButton" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="FontSize" Value="9" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="MaxWidth" Value="60" />
                        </Style>

                        <!-- Define styling for normal TextBlocks -->
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="0,0,0,5" />
                            <Setter Property="FontSize" Value="20" />
                        </Style>

                        <!-- Define styling for wrappanels -->
                        <Style TargetType="WrapPanel">
                            <Setter Property="Margin" Value="0,0,0,50" />
                        </Style>

                        <!-- Define styling for images -->
                        <Style TargetType="Image">
                            <Setter Property="MaxWidth" Value="50" />
                            <Setter Property="MaxHeight" Value="50" />
                        </Style>

                        <!-- Define styling for buttons -->
                        <Style TargetType="Button">
                            <Setter Property="Width" Value="55" />
                            <Setter Property="Height" Value="55" />
                        </Style>

                    </StackPanel.Resources>

                    <!-- Ask user their current mood -->
                    <TextBlock Text="How are you feeling?" />
                    <WrapPanel>

                        <!-- Im gonna just explain this stackpanel thing once because i dont wanna copy+paste this same comment or retype+reword over and over again and i use it a ton in this file-->
                        <!-- Each item in the wrappanel is a stackpanel, where the two items are the button/image and the caption text below it. It just lets me wrap two stacked items horizontally basically -->
                        <!-- I feel the need to comment this because its a pretty large piece of code (i also feel the need to comment almost everything for some reason) (this probably doesnt even need a comment tbh) -->
                        <StackPanel Margin="0,0,20,0">
                            <Button Command="{Binding Mood1Command}" Background="{Binding CurrentMood, Converter={StaticResource SelectedValueToColourConverter}, ConverterParameter=1}">
                                <Image Source="/assets/mood/Mood1Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Awful" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
                            <Button Command="{Binding Mood2Command}" Background="{Binding CurrentMood, Converter={StaticResource SelectedValueToColourConverter}, ConverterParameter=2}">
                                <Image Source="/assets/mood/Mood2Placeholder.png" />
                            </Button>
                            <TextBlock Style="{StaticResource TextButton}" Text="Sad" />
                        </StackPanel>

                        <StackPanel Margin="0,0,20,0">
