<UserControl x:Class="Paige.views.JournalSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Paige.views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">

        <!-- Split into two rows for a prompt and the buttons -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Back button -->
        <Button Grid.Row="0" Command="{Binding BackCommand}" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button.Content>
                <TextBlock Style="{StaticResource NormalText}" Text="Back" />
            </Button.Content>
        </Button>

        <!-- Prompt the user to choose if they want to see the journal calendar or to create a new entry -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10" Style="{StaticResource HeaderText1}" Text="Would you like to view the journal calendar or edit today's entry?" />
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource HeaderText2}" Text="(Choose one)" />
        </StackPanel>

        <!-- Set up grid in second row for the buttons -->
        <Grid Grid.Row="1">

            <!-- Split the grid into two columns -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Make the layout for the button in the left column -->
            <Grid Grid.Column="0">

                <!-- Split up the grid to size the button -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Create the button -->
                <Button Grid.Column="1" Command="{Binding CalendarCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Button.Content>
                        <TextBlock Style="{StaticResource HeaderText2}" Text="Journal Calendar" />
                    </Button.Content>
                </Button>

            </Grid>

            <!-- Make the layout for the button in the right column -->
            <Grid Grid.Column="1">

                <!-- Split up the grid to size the button -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>

                <!-- Create the button -->
                <Button Grid.Column="1" Command="{Binding JournalCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Button.Content>
                        <TextBlock Style="{StaticResource HeaderText2}" Text="Edit Entry" />
                    </Button.Content>
                </Button>

            </Grid>

        </Grid>

    </Grid>
    
</UserControl>
